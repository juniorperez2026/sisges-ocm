NODE_ENV=development
PORT=3000

APP_NAME=telefonia-backend
APP_VERSION=0.1.0

CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=debug

JWT_SECRET=change-this-value
JWT_EXPIRES_IN=15m


# ==================================================
# Telephony-owned SQL Server database
# ==================================================

SQL_SERVER_ENABLED=false
SQL_SERVER_HOST=172.23.1.180
SQL_SERVER_PORT=51601
SQL_SERVER_DATABASE=aval_pruebas_bi
SQL_SERVER_USERNAME=telefonia_app
SQL_SERVER_PASSWORD=change-this-value

SQL_SERVER_ENCRYPT=false
SQL_SERVER_TRUST_CERTIFICATE=true

SQL_SERVER_CONNECTION_TIMEOUT_MS=10000
SQL_SERVER_REQUEST_TIMEOUT_MS=15000
SQL_SERVER_POOL_MAX=5
SQL_SERVER_POOL_MIN=0
SQL_SERVER_POOL_IDLE_TIMEOUT_MS=30000

SQL_SERVER_TELEPHONY_SCHEMA=telefonia
SQL_SERVER_MIGRATIONS_TABLE=migrations
SQL_SERVER_MIGRATIONS_ENABLED=false


# ==================================================
# Legacy phone source — read only
# ==================================================

LEGACY_SQL_SERVER_ENABLED=false
LEGACY_SQL_SERVER_HOST=192.168.100.45
LEGACY_SQL_SERVER_PORT=51601
LEGACY_SQL_SERVER_DATABASE=aval_cob
LEGACY_SQL_SERVER_USERNAME=telefonia_legacy_reader
LEGACY_SQL_SERVER_PASSWORD=change-this-value

LEGACY_SQL_SERVER_ENCRYPT=false
LEGACY_SQL_SERVER_TRUST_CERTIFICATE=true

LEGACY_SQL_SERVER_CONNECTION_TIMEOUT_MS=10000
LEGACY_SQL_SERVER_REQUEST_TIMEOUT_MS=15000
LEGACY_SQL_SERVER_POOL_MAX=5
LEGACY_SQL_SERVER_POOL_MIN=0
LEGACY_SQL_SERVER_POOL_IDLE_TIMEOUT_MS=30000


# ==================================================
# Asterisk
# ==================================================

ASTERISK_ARI_URL=http://127.0.0.1:8088
ASTERISK_ARI_USERNAME=change-this-value
ASTERISK_ARI_PASSWORD=change-this-value
ASTERISK_APP_NAME=telefonia-backend


# ==================================================
# Phone normalization
# ==================================================

TELEPHONY_DEFAULT_COUNTRY_CODE=51
TELEPHONY_DEFAULT_AREA_CODE=1
LEGACY_PHONE_QUERY_LIMIT=20

# Accidental legacy schema cleanup
LEGACY_TELEPHONY_CLEANUP_ENABLED=false
LEGACY_TELEPHONY_CLEANUP_EXPECTED_DATABASE=aval_cob
